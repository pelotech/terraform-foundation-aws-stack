{
  extends: [
    'config:best-practices',
  ],
  dependencyDashboard: true,
  // CI regenerates terraform-docs and commits the README back to the PR branch
  // using a GitHub App token. Without this, Renovate sees a foreign author and
  // stops auto-rebasing the branch.
  gitIgnoredAuthors: [
    '245757523+pt-release-please[bot]@users.noreply.github.com',
  ],
  // The cni-bootstrap module pins CNI Helm chart versions as string literals in
  // locals, which Renovate's terraform manager does not parse. This custom
  // manager reads `# renovate: datasource=... depName=... [registryUrl=...]`
  // marker comments placed directly above each `version = "..."` line.
  customManagers: [
    {
      customType: 'regex',
      fileMatch: [
        '^modules/cni-bootstrap/main\\.tf$',
      ],
      matchStrings: [
        '#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?[^\\n]*\\n\\s*version\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      versioningTemplate: 'semver',
    },
  ],
  packageRules: [
    {
      description: 'Group terraform-aws-modules IAM updates together',
      matchDatasources: [
        'terraform-module',
      ],
      groupName: 'terraform-aws-modules/iam',
      matchPackageNames: [
        '/terraform-aws-modules/iam/',
      ],
    },
    {
      description: 'Group terraform-aws-modules EKS updates together',
      matchDatasources: [
        'terraform-module',
      ],
      groupName: 'terraform-aws-modules/eks',
      matchPackageNames: [
        '/terraform-aws-modules/eks/',
      ],
    },
  ],
}
